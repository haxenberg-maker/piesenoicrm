{
  "manifest_version": 3,
  "name": "CRM Piese Auto",
  "version": "1.0.0",
  "description": "Colectează produse din coșul furnizorului și le salvează în CRM-ul tău.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://ro.e-cat.intercars.eu/*",
    "https://*.supabase.co/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://ro.e-cat.intercars.eu/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "CRM Piese Auto"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*", "styles.css"],
      "matches": ["https://ro.e-cat.intercars.eu/*"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
